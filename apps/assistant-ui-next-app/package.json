{
  "name": "assistant-ui-starter-langchain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"yarn dev:frontend\" \"yarn dev:backend\"",
    "dev:frontend": "next dev --turbopack",
    "dev:backend": "langgraphjs dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint && oxfmt --check",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint:fix": "oxlint --fix && oxfmt",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.24",
    "@assistant-ui/react-langchain": "latest",
    "@assistant-ui/react-markdown": "^0.14.5",
